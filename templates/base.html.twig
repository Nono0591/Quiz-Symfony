<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Quiz{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: radial-gradient(circle at top, #1a1a2e, #0f0f1a);
            font-family: "Poppins", sans-serif;
            color: #e5e5e5;
        }

        .container {
            max-width: 900px;
            margin-top: 40px;
        }

        .gaming-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 0 25px rgba(138, 43, 226, 0.25);
            backdrop-filter: blur(8px);
            animation: fadeIn 0.4s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h1, h2, h3 {
            font-weight: 600;
            color: #ffffff;
        }

        .btn-gaming {
            background: linear-gradient(90deg, #6a00ff, #9d00ff);
            border: none;
            color: white;
            padding: 12px 25px;
            border-radius: 8px;
            font-weight: 600;
            transition: 0.2s;
        }

        .btn-gaming:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(157, 0, 255, 0.6);
        }

        .form-check-input:checked {
            background-color: #9d00ff;
            border-color: #9d00ff;
        }

        .form-check-label {
            font-size: 1.1rem;
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>

<body>
<div class="container">
    {% block body %}{% endblock %}
</div>

{% block javascripts %}{% endblock %}
</body>
</html>
