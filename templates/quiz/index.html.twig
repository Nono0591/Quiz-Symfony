{% extends 'base.html.twig' %}

{% block title %}Liste des Quiz{% endblock %}

{% block body %}
<h1 class="mb-4">Liste des Quiz</h1>

<div class="gaming-card">
    <table class="table table-dark table-hover">
        <thead>
            <tr>
                <th>Titre</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
        {% for quiz in quizzes %}
            <tr>
                <td>{{ quiz.title }}</td>
                <td>{{ quiz.description }}</td>
                <td>
                    <a href="{{ path('quiz_start', {id: quiz.id}) }}" class="btn btn-gaming btn-sm">Jouer</a>
                    <a href="{{ path('quiz_leaderboard', {id: quiz.id}) }}" class="btn btn-gaming btn-sm">Classement</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3" class="text-center">Aucun quiz trouvé.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
