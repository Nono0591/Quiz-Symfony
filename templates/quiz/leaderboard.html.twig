{% extends 'base.html.twig' %}

{% block title %}Classement - {{ quiz.title }}{% endblock %}

{% block body %}
<div class="gaming-card">

    <h1 class="mb-4">🏆 Classement : {{ quiz.title }}</h1>

    <table class="table table-dark table-striped table-hover" style="border-radius: 10px; overflow: hidden;">
        <thead>
            <tr style="background: rgba(157, 0, 255, 0.3);">
                <th>Position</th>
                <th>Pseudo</th>
                <th>Score</th>
            </tr>
        </thead>

        <tbody>
        {% for resultat in resultats %}
            <tr>
                <td><strong>#{{ loop.index }}</strong></td>
                <td>{{ resultat.participant.pseudo }}</td>
                <td>{{ resultat.score }} / {{ quiz.questions|length }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3" class="text-center py-3">Aucun résultat pour ce quiz.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_quiz_index') }}" class="btn-gaming mt-3">⬅ Retour aux quiz</a>

</div>
{% endblock %}
